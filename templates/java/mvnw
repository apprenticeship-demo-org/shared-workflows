#!/bin/sh
# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script, version 3.3.2
#
# Optional environment variables
# JAVA_HOME - location of a JDK home dir, required when type is jdk
# MAVEN_OPTS - parameters passed to the Java VM when running Maven
# MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ] ; then
  if [ -f /usr/local/etc/mavenrc ] ; then
    . /usr/local/etc/mavenrc
  fi
  if [ -f /etc/mavenrc ] ; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ] ; then
    . "$HOME/.mavenrc"
  fi
fi

# OS specific support.  $var _must_ be set to either true or false.
cygwin=false
darwin=false
mingw=false
case "$(uname)" in
  CYGWIN*) cygwin=true ;;
  MINGW*)  mingw=true  ;;
  Darwin*) darwin=true ;;
esac

# Attempt to find JAVA_HOME if not already set
if [ -z "$JAVA_HOME" ] ; then
  if [ "$darwin" = "true" ] ; then
    if [ -x '/usr/libexec/java_home' ] ; then
      JAVA_HOME=$(/usr/libexec/java_home) ; export JAVA_HOME
    elif [ -d "/System/Library/Frameworks/JavaVM.framework/Versions/CurrentJDK/Home" ] ; then
      JAVA_HOME="/System/Library/Frameworks/JavaVM.framework/Versions/CurrentJDK/Home"
      export JAVA_HOME
    fi
  fi
fi

if [ -z "$JAVA_HOME" ] ; then
  javaExecutable="$(which java)"
  if [ -n "$javaExecutable" ] ; then
    JAVA_HOME="$(dirname "$(dirname "$(readlink -f "$javaExecutable")")")"
    export JAVA_HOME
  fi
fi

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(pwd)}"
MVNW_VERBOSE="${MVNW_VERBOSE:-false}"

distributionUrl=
wrapperUrl=
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

if [ -f "$WRAPPER_PROPERTIES" ] ; then
  while IFS='=' read -r key value ; do
    case "$key" in
      distributionUrl) distributionUrl="$value" ;;
      wrapperUrl)      wrapperUrl="$value"      ;;
    esac
  done < "$WRAPPER_PROPERTIES"
fi

# Determine Maven home
MAVEN_USER_HOME="${MAVEN_USER_HOME:-${HOME}/.m2}"
MAVEN_WRAPPER_DIR="$MAVEN_USER_HOME/wrapper/dists"

# Derive directory name from distribution URL
distributionUrlName="${distributionUrl##*/}"
distributionUrlNameMain="${distributionUrlName%-bin.zip}"
MAVEN_HOME="$MAVEN_WRAPPER_DIR/$distributionUrlNameMain/*/$(ls "$MAVEN_WRAPPER_DIR/$distributionUrlNameMain" 2>/dev/null | head -1)"
MAVEN_HOME_EXPANDED="$MAVEN_WRAPPER_DIR/$distributionUrlNameMain"

# ── Fast path: Maven already cached ──────────────────────────────────────────
MAVEN_EXEC=""
if [ -d "$MAVEN_HOME_EXPANDED" ] ; then
  for d in "$MAVEN_HOME_EXPANDED"/*/bin ; do
    if [ -x "$d/mvn" ] ; then
      MAVEN_EXEC="$d/mvn"
      break
    fi
  done
fi

# ── Slow path: download and unpack ───────────────────────────────────────────
if [ -z "$MAVEN_EXEC" ] ; then
  if [ "$MVNW_VERBOSE" = "true" ] ; then
    echo "Downloading Apache Maven from: $distributionUrl"
  fi
  mkdir -p "$MAVEN_HOME_EXPANDED"
  tmpZip="$(mktemp)"
  if command -v wget > /dev/null 2>&1 ; then
    wget -q -O "$tmpZip" "$distributionUrl"
  elif command -v curl > /dev/null 2>&1 ; then
    curl -sS -L -o "$tmpZip" "$distributionUrl"
  else
    echo "Neither wget nor curl is available. Cannot download Maven." >&2
    exit 1
  fi
  unzip -q "$tmpZip" -d "$MAVEN_HOME_EXPANDED"
  rm -f "$tmpZip"
  for d in "$MAVEN_HOME_EXPANDED"/*/bin ; do
    if [ -x "$d/mvn" ] ; then
      MAVEN_EXEC="$d/mvn"
      break
    fi
  done
fi

if [ -z "$MAVEN_EXEC" ] ; then
  echo "Could not determine Maven executable after download. Check $MAVEN_HOME_EXPANDED" >&2
  exit 1
fi

exec "$MAVEN_EXEC" "$@"
