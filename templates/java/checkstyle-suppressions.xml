<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.0//EN"
    "https://checkstyle.org/dtds/suppressions_1_0.dtd">
<suppressions>
  <!--
    Suppress Checkstyle rules for test files.
    Test classes often need longer methods, magic numbers, and relaxed naming
    conventions without degrading the quality signal for production code.
  -->
  <suppress files=".*Test\.java$"     checks="MethodLength"      />
  <suppress files=".*Test\.java$"     checks="MagicNumber"       />
  <suppress files=".*Test\.java$"     checks="JavadocMethod"     />
  <suppress files=".*Test\.java$"     checks="JavadocVariable"   />
  <suppress files=".*Test\.java$"     checks="VisibilityModifier"/>

  <!--
    Add additional suppressions below as your project evolves.
    Format:
      <suppress files="<regex>" checks="<CheckName>" [lines="<range>"] [columns="<range>"] />

    Examples:
      Suppress a specific check in a generated file:
        <suppress files=".*Generated\.java$" checks=".*" />

      Suppress a check only on certain lines:
        <suppress files="App\.java$" checks="MagicNumber" lines="1-10" />
  -->
</suppressions>
